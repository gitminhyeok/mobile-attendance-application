{
  "devCommand": "uvicorn main:app --reload",
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "main.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "50 6 * * *"
    }
  ]
}